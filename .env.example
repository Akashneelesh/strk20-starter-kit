# Copy this file to .env.local and fill in your values.

# Alchemy Starknet RPC key — used by the mainnet + sepolia providers in
# src/utils/constants.ts. Get one free at https://alchemy.com. The URL prefix is
# already set in constants.ts; paste ONLY the key here.
NEXT_PUBLIC_PROVIDER_URL=your_alchemy_key_here

# (Optional) Your echo/anonymizer helper deployed on Sepolia — enables the Echo
# action there. Leave as 0x0 if not deployed; you can deploy one from the Echo tab
# in the app and paste the returned address here.
NEXT_PUBLIC_STRK20_ECHO_HELPER_SEPOLIA=0x0
